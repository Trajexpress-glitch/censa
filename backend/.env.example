# ─────────────────────────────────────────────────────────────
# CENSA — variables d'environnement du back-end
# Copie ce fichier en « .env » et remplis les valeurs.
# ⛔️ NE COMMITTE JAMAIS le vrai .env (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────

# Clé SECRÈTE Stripe — Dashboard → Développeurs → Clés API
# (commence par sk_test_ en test, sk_live_ en production)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret de signature du webhook — Dashboard → Développeurs → Webhooks
# → ton endpoint → « Signing secret » (commence par whsec_)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Clé PUBLIQUE — renvoyée au front (pk_test_ / pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# IDs de prix — Dashboard → Produits → (chaque prix) → price_...
# Mise en avant (publications boostées ET annonces d'emploi en avant)
PRICE_BOOST24=price_xxxxxxxxxxxxx   # 5 $  · 24 h
PRICE_BOOST48=price_xxxxxxxxxxxxx   # 10 $ · 48 h
PRICE_BOOST80=price_xxxxxxxxxxxxx   # 15 $ · 80 h

# (option) Boîte de réception par défaut des candidatures, si une
# annonce n'a pas d'e-mail de contact. Sinon l'e-mail de l'annonceur.
JOB_INBOX=

# URL(s) du front (redirections après paiement + CORS).
# Plusieurs domaines possibles, séparés par des virgules.
FRONTEND_URL=http://localhost:3000

# Port d'écoute (les hébergeurs le fixent souvent automatiquement)
PORT=4242
